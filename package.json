{
  "name": "pantoraya",
  "version": "1.3.0",
  "description": "Private, offline MP4, MP3, JPG, PDF compression and document-to-PDF conversion for macOS and Windows",
  "main": "src/main/main.js",
  "author": "Pantoraya",
  "license": "MIT",
  "homepage": "https://github.com/VodoooFilms/pantoraya#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VodoooFilms/pantoraya.git"
  },
  "bugs": {
    "url": "https://github.com/VodoooFilms/pantoraya/issues"
  },
  "keywords": [
    "macos",
    "windows",
    "ffmpeg",
    "mp4",
    "mp3",
    "jpg",
    "pdf",
    "docx",
    "rtf",
    "odt",
    "offline",
    "converter"
  ],
  "scripts": {
    "build:ffmpeg": "node scripts/build-ffmpeg.js",
    "build:pdf-helper": "node scripts/build-pdf-helper.js",
    "prepare:engines": "node scripts/prepare-engines.js",
    "prepare:windows": "node scripts/prepare-windows.js",
    "prestart": "npm run prepare:engines",
    "start": "electron .",
    "check": "node --check src/main/main.js && node --check src/preload/preload.js && node --check src/renderer/app.js && node --check src/main/converters/pdf.js && node --check src/main/converters/document.js && node --check scripts/build-pdf-helper.js && node --check scripts/build-ffmpeg.js && node --check scripts/prepare-engines.js && node --check scripts/prepare-windows.js",
    "test": "node --test",
    "prebuild": "npm run prepare:engines",
    "build": "npm run check && npm test && electron-builder --mac dmg --arm64",
    "build:win": "npm run prepare:windows && npm run check && npm test && electron-builder --win nsis --x64",
    "build:win:dir": "npm run prepare:windows && npm run check && npm test && electron-builder --win dir --x64",
    "prebuild:dir": "npm run prepare:engines",
    "build:dir": "npm run check && npm test && electron-builder --mac dir --arm64"
  },
  "build": {
    "appId": "com.pantoraya.converter",
    "productName": "Pantoraya",
    "artifactName": "Pantoraya-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/after-pack.js",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/licenses",
        "to": "licenses"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icons/icon.icns",
      "minimumSystemVersion": "13.4",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "extraResources": [
        { "from": "build/ffmpeg/ffmpeg", "to": "ffmpeg/ffmpeg" },
        { "from": "build/pdf/PantorayaPDF", "to": "pdf/PantorayaPDF" },
        { "from": "assets/locales/en.lproj/InfoPlist.strings", "to": "en.lproj/InfoPlist.strings" },
        { "from": "assets/locales/es.lproj/InfoPlist.strings", "to": "es.lproj/InfoPlist.strings" }
      ],
      "extendInfo": {
        "CFBundleName": "Pantoraya",
        "CFBundleDisplayName": "Pantoraya",
        "NSDesktopFolderUsageDescription": "Pantoraya necesita acceder a tu Escritorio para abrir archivos, mostrar miniaturas y guardar conversiones.",
        "NSDocumentsFolderUsageDescription": "Pantoraya necesita acceder a Documentos para abrir archivos, mostrar miniaturas y guardar conversiones.",
        "NSDownloadsFolderUsageDescription": "Pantoraya necesita acceder a Descargas para abrir archivos, mostrar miniaturas y guardar conversiones.",
        "NSHumanReadableCopyright": "Copyright © 2026 Pantoraya"
      }
    },
    "win": {
      "icon": "assets/icons/icon.png",
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        { "from": "build/windows/ffmpeg.exe", "to": "ffmpeg/ffmpeg.exe" },
        { "from": "src/windows/convert-document.ps1", "to": "windows/convert-document.ps1" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pantoraya",
      "uninstallDisplayName": "Pantoraya"
    },
    "dmg": {
      "title": "Pantoraya ${version}",
      "icon": "assets/icons/icon.icns",
      "iconSize": 128,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 190,
          "type": "file"
        },
        {
          "x": 390,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "extract-zip": "^2.0.1"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
